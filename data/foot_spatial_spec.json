{
  "schema_version": "1.0",
  "name": "foot_spatial_spec",
  "object": {
    "id": "foot",
    "label": "Foot",
    "domain": "anatomical_visual_reasoning",
    "description": "Structured spatial knowledge for reasoning about foot bone views, camera orientation, image-space layout, and anatomical directions."
  },
  "core_principles": [
    {
      "id": "object_vs_image_space",
      "principle": "Object-space anatomical relations are stable, while image-space layout changes with camera angle and image roll.",
      "example": "ToeBones are distal to AnkleRegion in object space, but ToeBones may appear at the bottom, top, left, or right of an image depending on camera and roll."
    },
    {
      "id": "view_vs_image_orientation",
      "principle": "A view class describes where the camera is relative to the foot. Image orientation describes where parts appear on the 2D screen.",
      "example": "DorsalTopDown remains a dorsal view whether toes appear at the bottom or top of the image."
    },
    {
      "id": "minimal_update",
      "principle": "When iterating toward a target render, change only camera/view parameters required by the diagnosed mismatch unless the target explicitly requires rendering changes."
    }
  ],
  "anatomical_axes": {
    "proximal_distal": {
      "axis_id": "proximal_distal",
      "positive_direction": "distal",
      "negative_direction": "proximal",
      "distal": {
        "definition": "Toward the toes; farther from the body center.",
        "points_toward": [
          "ToeBones",
          "Phalanges",
          "DistalToeEnd"
        ]
      },
      "proximal": {
        "definition": "Toward the ankle/heel; closer to the body center.",
        "points_toward": [
          "AnkleRegion",
          "Tarsals",
          "Calcaneus",
          "Talus",
          "ProximalAnkleEnd"
        ]
      }
    },
    "dorsal_plantar": {
      "axis_id": "dorsal_plantar",
      "positive_direction": "dorsal",
      "negative_direction": "plantar",
      "dorsal": {
        "definition": "Top surface of the foot.",
        "points_toward": [
          "DorsalSurface",
          "DorsalTopDown"
        ]
      },
      "plantar": {
        "definition": "Bottom/sole surface of the foot.",
        "points_toward": [
          "PlantarSurface",
          "PlantarBottomUp"
        ]
      }
    },
    "medial_lateral": {
      "axis_id": "medial_lateral",
      "positive_direction": "medial",
      "negative_direction": "lateral",
      "medial": {
        "definition": "Big-toe side of the foot; toward the body midline in anatomical position.",
        "points_toward": [
          "Hallux",
          "FirstMetatarsal",
          "MedialSide"
        ]
      },
      "lateral": {
        "definition": "Little-toe side of the foot; away from the body midline in anatomical position.",
        "points_toward": [
          "FifthToe",
          "FifthMetatarsal",
          "LateralSide"
        ]
      }
    }
  },
  "parts": {
    "Foot": {
      "type": "object",
      "description": "Complete foot skeleton object used for rendering and spatial view reasoning.",
      "has_parts": [
        "ToeBones",
        "Metatarsals",
        "Tarsals",
        "AnkleRegion"
      ],
      "has_surfaces": [
        "DorsalSurface",
        "PlantarSurface",
        "MedialSideSurface",
        "LateralSideSurface"
      ]
    },
    "ToeBones": {
      "type": "region",
      "aliases": [
        "Phalanges",
        "Toes"
      ],
      "description": "Distal small bones of the foot, including big toe through little toe.",
      "has_parts": [
        "Hallux",
        "SecondToe",
        "ThirdToe",
        "FourthToe",
        "FifthToe"
      ],
      "object_space_location": {
        "proximal_distal": "distal",
        "dorsal_plantar": "both",
        "medial_lateral": "spans_medial_to_lateral"
      },
      "visual_cues": [
        "Several small segmented bones",
        "Located at the distal/front end of the foot",
        "Often appear as separate toe rays"
      ]
    },
    "Hallux": {
      "type": "part",
      "aliases": [
        "BigToe",
        "FirstToe"
      ],
      "description": "Big toe; medial-most toe.",
      "object_space_location": {
        "proximal_distal": "distal",
        "medial_lateral": "medial"
      },
      "visual_cues": [
        "Usually larger/thicker than other toes",
        "Located on the medial side"
      ]
    },
    "SecondToe": {
      "type": "part",
      "description": "Second toe bone group.",
      "object_space_location": {
        "proximal_distal": "distal",
        "medial_lateral": "near_medial"
      }
    },
    "ThirdToe": {
      "type": "part",
      "description": "Middle toe bone group.",
      "object_space_location": {
        "proximal_distal": "distal",
        "medial_lateral": "central"
