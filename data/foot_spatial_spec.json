    "ProximalDorsalOblique": {
      "view_type": "oblique",
      "primary_axis": "proximal",
      "secondary_axis": "dorsal",
      "description": "View from ankle/heel end with some top/dorsal visibility.",
      "expected_visible": {
        "primary_surfaces": [
          "ProximalEndSurface"
        ],
        "secondary_surfaces": [
          "DorsalSurface"
        ],
        "emphasized_parts": [
          "AnkleRegion",
          "Tarsals",
          "Metatarsals"
        ]
      }
    }
  },
  "image_observation_schema": {
    "description": "Recommended structure for a visual diagnosis produced from the current image.",
    "fields": {
      "visible_parts": {
        "type": "array[string]",
        "examples": [
          "ToeBones",
          "Metatarsals",
          "Tarsals",
          "AnkleRegion"
        ]
      },
      "dominant_surface_or_side": {
        "type": "string",
        "examples": [
          "dorsal",
          "plantar",
          "medial",
          "lateral",
          "distal",
          "proximal",
          "unknown"
        ]
      },
      "image_layout": {
        "type": "object",
        "description": "2D screen-space location of anatomical parts.",
        "allowed_locations": [
          "top",
          "bottom",
          "left",
          "right",
          "center",
          "upper_left",
          "upper_right",
          "lower_left",
          "lower_right",
          "unknown"
        ],
        "example": {
          "ToeBones": "bottom",
          "AnkleRegion": "top",
          "Hallux": "left",
          "FifthToe": "right"
        }
      },
      "visual_cues": {
        "type": "object",
        "example": {
          "top_surface_visible": true,
          "bottom_surface_visible": false,
          "side_depth_visible": true,
          "toe_end_closest": false,
          "ankle_end_closest": false
        }
      },
      "inferred_current_view": {
        "type": "string",
        "examples": [
          "DorsalTopDown",
          "DorsomedialOblique",
          "MedialSide",
          "unknown"
        ]
      },
      "confidence": {
        "type": "number",
        "range": [
          0,
          1
        ]
      }
    }
  },
  "reasoning_rules": [
    {
      "id": "classify_dorsal_topdown",
      "if": [
        "dominant_surface_or_side == dorsal",
        "side_depth_visible == false or minimal",
        "plantar_surface_dominates == false"
      ],
      "then": {
        "view": "DorsalTopDown",
        "diagnosis": "The camera is mostly above the foot looking from dorsal toward plantar."
      }
    },
    {
      "id": "classify_plantar_bottomup",
      "if": [
        "dominant_surface_or_side == plantar",
        "side_depth_visible == false or minimal",
        "dorsal_surface_dominates == false"
      ],
      "then": {
        "view": "PlantarBottomUp",
        "diagnosis": "The camera is mostly below the foot looking from plantar toward dorsal."
      }
    },
    {
      "id": "classify_medial_side",
      "if": [
        "dominant_surface_or_side == medial",
        "Hallux or FirstMetatarsal is emphasized",
        "FifthToe or FifthMetatarsal is not dominant"
      ],
      "then": {
        "view": "MedialSide",
        "diagnosis": "The camera is on the big-toe side looking toward the little-toe side."
      }
    },
    {
      "id": "classify_lateral_side",
      "if": [
        "dominant_surface_or_side == lateral",
        "FifthToe or FifthMetatarsal is emphasized",
        "Hallux or FirstMetatarsal is not dominant"
      ],
      "then": {
        "view": "LateralSide",
        "diagnosis": "The camera is on the little-toe side looking toward the big-toe side."
      }
    },
    {
      "id": "classify_distal_toe_end",
      "if": [
        "ToeBones are closest or frontal",
        "camera appears to look from toes toward ankle",
        "AnkleRegion is behind or partially hidden"
      ],
      "then": {
        "view": "DistalToeEnd",
        "diagnosis": "The camera is at the toe end looking toward the ankle/heel end."
      }
    },
    {
      "id": "classify_proximal_ankle_end",
      "if": [
        "AnkleRegion or Tarsals are closest or frontal",
        "camera appears to look from ankle/heel toward toes",
        "ToeBones are behind or farther away"
      ],
      "then": {
        "view": "ProximalAnkleEnd",
        "diagnosis": "The camera is at the ankle/heel end looking toward the toes."
      }
    },
    {
      "id": "detect_dorsal_oblique",
      "if": [
        "dorsal/top surface is visible",
        "side_depth_visible == true"
      ],
      "then": {
        "not_view": "PureDorsalTopDown",
        "possible_views": [
          "DorsomedialOblique",
          "DorsolateralOblique",
          "DistalDorsalOblique",
          "ProximalDorsalOblique"
        ],
        "diagnosis": "The view is dorsal-oblique rather than pure top-down."
      }
    },
    {
      "id": "infer_toes_bottom_orientation",
      "if": [
        "image_layout.ToeBones == bottom",
        "image_layout.AnkleRegion == top"
      ],
      "then": {
        "image_orientation": "toes_bottom_ankle_top",
        "interpretation": "The screen vertical axis maps roughly from proximal at top to distal at bottom."
      }
    },
    {
      "id": "infer_toes_top_orientation",
      "if": [
        "image_layout.ToeBones == top",
        "image_layout.AnkleRegion == bottom"
      ],
      "then": {
        "image_orientation": "toes_top_ankle_bottom",
        "interpretation": "This can be the same anatomical view as toes-bottom but with approximately 180 degree image roll."
      }
    },
    {
      "id": "do_not_confuse_roll_with_view",
      "if": [
        "same surface is visible",
        "same camera_from direction is implied",
        "only ToeBones/AnkleRegion screen positions are swapped"
      ],
      "then": {
        "diagnosis": "Likely image roll/orientation mismatch, not a different anatomical view.",
        "update_hint": "Adjust camera roll/view_up rather than changing the main camera side."
      }
    },
    {
      "id": "minimal_update_rule",
      "if": [
        "target mismatch is mainly view angle"
      ],
      "then": {
        "update_hint": "Change camera position, focal point, view direction, or view_up only. Do not change opacity, color transfer function, isovalue, or rendering style unless explicitly required."
      }
    }
  ],
  "target_interpretation_guidelines": [
    {
      "target_phrase": "dorsal top-down view",
      "interpret_as": "DorsalTopDown",
      "requirements": [
        "Camera from dorsal side",
        "Looks toward plantar side",
        "Dorsal/top surface dominates",
        "Side depth minimal unless target says oblique"
      ]
    },
    {
      "target_phrase": "plantar bottom-up view",
      "interpret_as": "PlantarBottomUp",
      "requirements": [
        "Camera from plantar/sole side",
        "Looks toward dorsal side",
        "Plantar/bottom surface dominates"
      ]
    },
    {
      "target_phrase": "medial side view",
      "interpret_as": "MedialSide",
      "requirements": [
        "Camera from big-toe side",
        "Looks toward little-toe side",
        "Hallux/first metatarsal side emphasized"
      ]
    },
    {
      "target_phrase": "lateral side view",
      "interpret_as": "LateralSide",
      "requirements": [
        "Camera from little-toe side",
        "Looks toward big-toe side",
        "Fifth toe/fifth metatarsal side emphasized"
      ]
    },
    {
      "target_phrase": "distal view or toe-end view",
      "interpret_as": "DistalToeEnd",
      "requirements": [
        "Camera from toe end",
        "Looks toward ankle/heel end",
        "Toe ends are frontal/closest"
      ]
    },
    {
      "target_phrase": "proximal view or ankle-end view",
      "interpret_as": "ProximalAnkleEnd",
      "requirements": [
        "Camera from ankle/heel end",
        "Looks toward toe end",
        "Ankle/tarsal region is frontal/closest"
      ]
    },
    {
      "target_phrase": "oblique angle",
      "interpret_as": "ObliqueViewFamily",
      "requirements": [
        "Primary surface or side still identifiable",
        "At least one secondary side/depth component visible",
        "Do not classify as pure canonical view if side/depth is significant"
      ]
    }
  ],
  "agent_prompt_instructions": [
    "Use this JSON as the source of truth for anatomical directions and canonical view definitions.",
    "Always distinguish object-space anatomical facts from image-space observations.",
    "Classify the intended target view using canonical_views and oblique_view_families.",
    "Compare the current visual diagnosis against expected_visible and expected_visual_cues.",
    "Identify the smallest mismatch between current image and target view.",
    "Recommend the minimal camera/rendering update required to fix that mismatch.",
    "Do not invent new anatomical facts outside this JSON unless the visual evidence requires a cautious unknown/uncertain label.",
    "Do not treat screen position alone as anatomical view. Screen position may be caused by camera roll or image orientation."
  ],
  "sample_reasoning_examples": [
    {
      "target": "Show the foot bones in dorsal top-down view with toes at the bottom and ankle at the top.",
      "expected_interpretation": {
        "view": "DorsalTopDown",
