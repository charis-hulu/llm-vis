        "medial_lateral": "medial_to_central"
      }
    },
    "AnkleRegion": {
      "type": "region",
      "aliases": [
        "HeelAnkleRegion",
        "ProximalFootRegion"
      ],
      "description": "Proximal region of the foot skeleton around ankle and heel/tarsal cluster.",
      "object_space_location": {
        "proximal_distal": "proximal"
      },
      "visual_cues": [
        "Compact cluster near top/back of foot depending on orientation",
        "Opposite end from toe bones"
      ]
    }
  },
  "surfaces": {
    "DorsalSurface": {
      "definition": "Top surface of the foot.",
      "opposite": "PlantarSurface",
      "best_seen_in": [
        "DorsalTopDown",
        "DorsomedialOblique",
        "DorsolateralOblique",
        "DistalDorsalOblique",
        "ProximalDorsalOblique"
      ]
    },
    "PlantarSurface": {
      "definition": "Bottom/sole surface of the foot.",
      "opposite": "DorsalSurface",
      "best_seen_in": [
        "PlantarBottomUp",
        "PlantarmedialOblique",
        "PlantarlateralOblique"
      ]
    },
    "MedialSideSurface": {
      "definition": "Side surface on the big-toe side.",
      "opposite": "LateralSideSurface",
      "best_seen_in": [
        "MedialSide",
        "DorsomedialOblique",
        "PlantarmedialOblique"
      ]
    },
    "LateralSideSurface": {
      "definition": "Side surface on the little-toe side.",
      "opposite": "MedialSideSurface",
      "best_seen_in": [
        "LateralSide",
        "DorsolateralOblique",
        "PlantarlateralOblique"
      ]
    },
    "DistalEndSurface": {
      "definition": "End of the foot facing the toes.",
      "opposite": "ProximalEndSurface",
      "best_seen_in": [
        "DistalToeEnd",
        "DistalDorsalOblique"
      ]
    },
    "ProximalEndSurface": {
      "definition": "End of the foot facing ankle/heel.",
      "opposite": "DistalEndSurface",
      "best_seen_in": [
        "ProximalAnkleEnd",
        "ProximalDorsalOblique"
      ]
    }
  },
