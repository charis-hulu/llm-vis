        "Talus",
        "Calcaneus",
        "Navicular",
        "Cuboid",
        "Cuneiforms"
      ],
      "object_space_location": {
        "proximal_distal": "proximal",
        "medial_lateral": "spans_medial_to_lateral"
      },
      "visual_cues": [
        "Compact clustered bones",
        "Located proximal to metatarsals",
        "Near ankle/heel region"
      ]
    },
    "Talus": {
      "type": "part",
      "description": "Tarsal bone near ankle articulation.",
      "object_space_location": {
        "proximal_distal": "proximal",
        "dorsal_plantar": "more_dorsal"
      }
    },
    "Calcaneus": {
      "type": "part",
      "aliases": [
        "HeelBone"
      ],
      "description": "Heel bone; large proximal/posterior tarsal bone.",
      "object_space_location": {
        "proximal_distal": "proximal",
        "dorsal_plantar": "more_plantar"
      }
    },
    "Navicular": {
      "type": "part",
      "description": "Medial tarsal bone between talus and cuneiforms.",
      "object_space_location": {
        "proximal_distal": "proximal",
        "medial_lateral": "medial"
      }
    },
    "Cuboid": {
      "type": "part",
      "description": "Lateral tarsal bone near fourth/fifth metatarsals.",
      "object_space_location": {
