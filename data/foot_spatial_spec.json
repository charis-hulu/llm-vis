          "Side depth minimal"
        ]
      }
    },
    {
      "target": "Show a medial side view.",
      "expected_interpretation": {
        "view": "MedialSide",
        "requirements": [
          "Camera from medial/big-toe side",
          "Looks toward lateral/little-toe side",
          "Hallux and FirstMetatarsal side emphasized"
        ]
      }
    },
    {
      "target": "The current view is slightly oblique from above.",
      "expected_interpretation": {
        "view_family": "Dorsal oblique",
        "requirements": [
          "Dorsal surface visible",
          "Some side/depth visible",
          "Not pure DorsalTopDown"
        ]
      }
    }
  ]
}