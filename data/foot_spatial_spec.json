        "proximal_distal": "distal",
        "medial_lateral": "lateral"
      },
      "visual_cues": [
        "Smallest/lateral toe",
        "Located on the lateral side"
      ]
    },
    "Metatarsals": {
      "type": "region",
      "description": "Long bones between toe bones and tarsal/ankle region.",
      "has_parts": [
