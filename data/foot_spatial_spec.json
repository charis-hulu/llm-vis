        "SecondMetatarsal",
        "ThirdMetatarsal",
        "FourthMetatarsal",
        "FifthMetatarsal"
      ],
      "object_space_location": {
        "proximal_distal": "middle_distal",
        "medial_lateral": "spans_medial_to_lateral"
      },
      "visual_cues": [
        "Long ray-like bones",
        "Between toes and tarsals"
      ]
    },
    "FirstMetatarsal": {
      "type": "part",
      "description": "Metatarsal associated with the big toe; medial side.",
      "object_space_location": {
        "proximal_distal": "middle_distal",
        "medial_lateral": "medial"
      }
    },
    "SecondMetatarsal": {
      "type": "part",
      "description": "Second metatarsal.",
      "object_space_location": {
        "proximal_distal": "middle_distal",
        "medial_lateral": "near_medial"
      }
    },
    "ThirdMetatarsal": {
      "type": "part",
      "description": "Third metatarsal.",
      "object_space_location": {
        "proximal_distal": "middle_distal",
        "medial_lateral": "central"
      }
    },
    "FourthMetatarsal": {
      "type": "part",
      "description": "Fourth metatarsal.",
      "object_space_location": {
        "proximal_distal": "middle_distal",
        "medial_lateral": "near_lateral"
      }
    },
    "FifthMetatarsal": {
      "type": "part",
      "description": "Metatarsal associated with the little toe; lateral side.",
