  "canonical_views": {
    "DorsalTopDown": {
      "view_type": "canonical",
      "camera_from": "dorsal",
      "looks_toward": "plantar",
      "primary_axis": "dorsal_plantar",
      "opposite_view": "PlantarBottomUp",
      "description": "Camera is above the top of the foot, looking downward toward the plantar/sole side.",
      "expected_visible": {
        "primary_surfaces": [
          "DorsalSurface"
        ],
        "primary_parts": [
          "ToeBones",
          "Metatarsals",
          "Tarsals",
          "AnkleRegion"
        ],
        "secondary_surfaces": [],
        "minimal_or_hidden": [
          "PlantarSurface",
          "MedialSideSurface",
          "LateralSideSurface"
        ]
      },
      "expected_visual_cues": [
        "Top/dorsal surface dominates",
        "Toe rays and metatarsals are visible from above",
        "Side depth should be minimal for a pure top-down view"
      ],
      "common_image_orientations": [
        {
          "name": "toes_bottom_ankle_top",
          "ToeBones": "bottom",
          "AnkleRegion": "top",
          "interpretation": "Image vertical axis roughly maps proximal-to-distal, with distal/toes downward."
        },
        {
          "name": "toes_top_ankle_bottom",
          "ToeBones": "top",
          "AnkleRegion": "bottom",
          "interpretation": "Same anatomical view as dorsal top-down, but image roll is approximately 180 degrees from toes_bottom_ankle_top."
        }
      ],
      "camera_update_hint": {
        "make_more_like_this": "Move camera toward dorsal side and look toward plantar side; reduce oblique side component.",
        "if_side_depth_too_visible": "Reduce tilt/oblique component; align view direction more closely with dorsal-to-plantar axis."
      }
    },
    "PlantarBottomUp": {
      "view_type": "canonical",
      "camera_from": "plantar",
      "looks_toward": "dorsal",
      "primary_axis": "dorsal_plantar",
      "opposite_view": "DorsalTopDown",
      "description": "Camera is below the sole of the foot, looking upward toward the dorsal/top side.",
      "expected_visible": {
        "primary_surfaces": [
          "PlantarSurface"
        ],
        "primary_parts": [
          "ToeBones",
          "Metatarsals",
          "Tarsals",
          "AnkleRegion"
        ],
        "secondary_surfaces": [],
        "minimal_or_hidden": [
          "DorsalSurface",
          "MedialSideSurface",
          "LateralSideSurface"
        ]
      },
      "expected_visual_cues": [
        "Plantar/sole side dominates",
        "Opposite of dorsal top-down",
        "Side depth should be minimal for a pure bottom-up view"
      ],
      "camera_update_hint": {
        "make_more_like_this": "Move camera toward plantar side and look toward dorsal side."
      }
    },
    "MedialSide": {
      "view_type": "canonical",
      "camera_from": "medial",
      "looks_toward": "lateral",
      "primary_axis": "medial_lateral",
      "opposite_view": "LateralSide",
      "description": "Camera views the foot from the big-toe side toward the little-toe side.",
      "expected_visible": {
        "primary_surfaces": [
          "MedialSideSurface"
        ],
        "primary_parts": [
          "Hallux",
          "FirstMetatarsal",
          "Navicular",
          "Cuneiforms"
        ],
        "secondary_surfaces": [
          "DorsalSurface",
          "PlantarSurface"
        ],
        "minimal_or_hidden": [
          "LateralSideSurface",
          "FifthToe",
          "FifthMetatarsal"
        ]
      },
      "expected_visual_cues": [
        "Big-toe side is emphasized",
        "Hallux/first metatarsal side is more visible",
        "Foot profile is seen from the medial side"
      ],
      "camera_update_hint": {
        "make_more_like_this": "Move camera toward medial/big-toe side and look toward lateral/little-toe side.",
        "if_little_toe_side_dominates": "Rotate camera around the foot to the opposite side until big-toe side dominates."
      }
    },
    "LateralSide": {
      "view_type": "canonical",
      "camera_from": "lateral",
      "looks_toward": "medial",
      "primary_axis": "medial_lateral",
      "opposite_view": "MedialSide",
      "description": "Camera views the foot from the little-toe side toward the big-toe side.",
      "expected_visible": {
        "primary_surfaces": [
          "LateralSideSurface"
        ],
        "primary_parts": [
          "FifthToe",
          "FifthMetatarsal",
          "Cuboid"
        ],
        "secondary_surfaces": [
          "DorsalSurface",
          "PlantarSurface"
        ],
        "minimal_or_hidden": [
          "MedialSideSurface",
          "Hallux",
          "FirstMetatarsal"
        ]
      },
      "expected_visual_cues": [
        "Little-toe side is emphasized",
        "Fifth toe/fifth metatarsal side is more visible",
        "Foot profile is seen from the lateral side"
      ],
      "camera_update_hint": {
        "make_more_like_this": "Move camera toward lateral/little-toe side and look toward medial/big-toe side.",
        "if_big_toe_side_dominates": "Rotate camera around the foot to the opposite side until little-toe side dominates."
      }
    },
    "DistalToeEnd": {
      "view_type": "canonical",
      "camera_from": "distal",
      "looks_toward": "proximal",
      "primary_axis": "proximal_distal",
      "opposite_view": "ProximalAnkleEnd",
      "description": "Camera is placed in front of the toes, looking from the toe end toward the ankle/heel end.",
      "expected_visible": {
        "primary_surfaces": [
          "DistalEndSurface"
        ],
        "primary_parts": [
          "ToeBones",
          "Hallux",
          "SecondToe",
          "ThirdToe",
          "FourthToe",
          "FifthToe"
        ],
        "secondary_parts": [
          "Metatarsals"
        ],
        "minimal_or_hidden": [
          "ProximalEndSurface",
          "AnkleRegion"
        ]
      },
      "expected_visual_cues": [
        "Toe ends are closest to the camera",
        "Metatarsals extend away from the viewer toward ankle region",
        "Ankle/tarsals may be partly hidden behind distal structures"
      ],
      "camera_update_hint": {
        "make_more_like_this": "Move camera toward distal/toe end and look toward proximal/ankle end."
      }
    },
    "ProximalAnkleEnd": {
      "view_type": "canonical",
      "camera_from": "proximal",
      "looks_toward": "distal",
      "primary_axis": "proximal_distal",
      "opposite_view": "DistalToeEnd",
      "description": "Camera is placed near the ankle/heel end, looking from proximal region toward the toes.",
      "expected_visible": {
        "primary_surfaces": [
          "ProximalEndSurface"
        ],
        "primary_parts": [
          "AnkleRegion",
          "Tarsals",
          "Talus",
          "Calcaneus"
        ],
        "secondary_parts": [
          "Metatarsals"
        ],
        "minimal_or_hidden": [
          "DistalEndSurface",
          "ToeBones"
        ]
      },
      "expected_visual_cues": [
        "Ankle/tarsal cluster is closest to the camera",
        "Metatarsals and toes extend away from the viewer",
        "Opposite of distal toe-end view"
      ],
      "camera_update_hint": {
        "make_more_like_this": "Move camera toward proximal/ankle end and look toward distal/toe end."
      }
    }
  },
  "oblique_view_families": {
    "DorsomedialOblique": {
      "view_type": "oblique",
      "primary_axis": "dorsal",
      "secondary_axis": "medial",
      "description": "Mostly dorsal/top view with a medial/big-toe-side component.",
      "expected_visible": {
        "primary_surfaces": [
          "DorsalSurface"
        ],
        "secondary_surfaces": [
          "MedialSideSurface"
        ],
        "primary_parts": [
          "ToeBones",
          "Metatarsals",
          "Tarsals"
        ],
        "emphasized_parts": [
          "Hallux",
          "FirstMetatarsal"
        ]
      },
      "diagnosis_rule": "If dorsal surface is visible and big-toe side/depth is also visible, classify as dorsomedial oblique rather than pure dorsal top-down."
    },
    "DorsolateralOblique": {
